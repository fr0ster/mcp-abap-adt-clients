      params:
        top: 20
        inlinecount: "allpages"
        user: ""      # Optional: ADT user for user-filtered dump feed
        dump_id: ""   # Optional: when empty, test tries to discover ID from feed
        dump_class_name: "ZAC_SHR_DMP01"  # Pre-existing shared class that produces a dump (division by zero)
        generate_artificial_dump: true     # Run shared dump class to generate a fresh dump
