      description: "Run program via AdtExecutor (with and without profiling)"
      params:
        program_name: "ZAC_PROG023"
        source_code: |
          REPORT {{PROGRAM_NAME}}.

          WRITE: / 'PROGRAM_EXECUTOR_RUN_PROBE( ) = 1'.
        profiling:
