# Where-Used (getWhereUsed, getWhereUsedList, getWhereUsedScope)
# Searches for references to an ABAP object across the system.
# Two-step flow: 1) GET scope (available object types), 2) POST search with scope.
# Supported object types: class, program, include, functionGroup, functionModule,
#   interface, package, table, structure, domain, dataElement, view (CDS)
where_used:
  test_cases:
    - name: "where_used_default_scope"
      enabled: true
      description: "Test getWhereUsed with default scope (Eclipse default behavior). Uses shared_dependencies.tables."
      params:
        object_name: "ZAC_SHR_VTABL"  # → shared_dependencies.tables (referenced by ZAC_SHR_CDSUT_DDLS)
        object_type: "table"  # class | program | include | functionGroup | functionModule | interface | package | table | structure | domain | dataElement | view

    - name: "where_used_all_types"
      enabled: true
      description: "Test getWhereUsed with all types enabled (Eclipse 'select all' behavior). Uses shared_dependencies.tables."
      params:
        object_name: "ZAC_SHR_VTABL"  # → shared_dependencies.tables
        object_type: "table"

    - name: "where_used_table"
      enabled: true
      description: "Test getWhereUsed for table object type. Uses shared_dependencies.tables."
      params:
        object_name: "ZAC_SHR_VTABL"  # → shared_dependencies.tables
        object_type: "table"

    - name: "where_used_error_no_name"
      enabled: true
      description: "Validate error when object name is missing"
      params: {}

    - name: "where_used_error_no_type"
      enabled: true
      description: "Validate error when object type is missing"
      params: {}

    - name: "where_used_list_parsed"
      enabled: true
      description: "Test getWhereUsedList with parsed results. Uses shared_dependencies.tables."
      params:
        object_name: "ZAC_SHR_VTABL"  # → shared_dependencies.tables
        object_type: "table"
        enable_all_types: true

    - name: "where_used_list_raw_xml"
