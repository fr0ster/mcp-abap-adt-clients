# Create CDS Unit Test
create_cds_unit_test:
  test_cases:
    - name: "cds_unit_test"
      enabled: true
      description: "CDS view with ABAP Unit verification (dependencies auto-created)"
      params:
        # package_name: "ZAC_PKG01"  # Uses environment.default_package if omitted
        view_name: "ZAC_SHR_CDSUT_DDLS"     # → shared_dependencies.views
        description: "CDS Unit Test for ZAC_SHR_CDSUT_DDLS"
        # transport_request: ""  # Uses environment.default_transport if omitted
        dep_table_name: "ZAC_SHR_VTABL"  # → shared_dependencies.tables
        # skip_cleanup: false  # Set to true to skip cleanup after test (test class left for analysis)
        # Note: CDS view and table must be created manually before running this test
        unit_test_options:
          scope:
            ownTests: true
            foreignTests: false
          riskLevel:
            harmless: true
            dangerous: true
            critical: true
          duration:
            short: true
            medium: true
            long: true
        unit_test_status:
          with_long_polling: true
        unit_test_result:
          with_navigation_uris: false
          format: "abapunit"
        cds_unit_test:
          class_name: "ZAC_CDSUT_CLS"
          test_class_name: "LTC_ZAC_SHR_CDSUT_DDLS"
          description: "CDS unit test class"
          # transport_request: ""  # Uses environment.default_transport if omitted
          template_xml: |
            <abapsource:template abapsource:name="IF_FOR_AUTO_CLASS_GENERATION">
              <abapsource:property abapsource:key="CCAU_CONTENT">&lt;?xml version="1.0" encoding="UTF-8"?&gt;
            &lt;cds:cdstobetested xmlns:cds="http://www.sap.com/adt/cdsfrwk/cds"&gt;
              &lt;cds:cdsundertest api_doc="true" cds_name="ZAC_SHR_CDSUT_DDLS" cds_test_type="UNIT_TEST"&gt;
                &lt;cds:testmethods&gt;
                  &lt;cds:testmethod test_method_name="AUNIT_FOR_CDS_METHOD"/&gt;
                &lt;/cds:testmethods&gt;
              &lt;/cds:cdsundertest&gt;
            &lt;/cds:cdstobetested&gt;
            </abapsource:property>
              <abapsource:property abapsource:key="Content-Type">application/vnd.sap.adt.oo.cds.codgen.v1+xml</abapsource:property>
            </abapsource:template>
          test_class_source: |
            "!@testing ZAC_CDSUT_CLS
            CLASS LTC_ZAC_SHR_CDSUT_DDLS DEFINITION FINAL
              FOR TESTING RISK LEVEL HARMLESS DURATION SHORT.

              PRIVATE SECTION.
                CLASS-DATA environment TYPE REF TO if_cds_test_environment.

                DATA td_zac_shr_vtabl TYPE STANDARD TABLE OF zac_shr_vtabl WITH EMPTY KEY.
                DATA act_results TYPE STANDARD TABLE OF zac_shr_cdsut_ddls WITH EMPTY KEY.

                CLASS-METHODS class_setup RAISING cx_static_check.
                CLASS-METHODS class_teardown.

                METHODS setup RAISING cx_static_check.
                METHODS prepare_testdata.
                METHODS aunit_for_cds_method FOR TESTING RAISING cx_static_check.
            ENDCLASS.

            CLASS LTC_ZAC_SHR_CDSUT_DDLS IMPLEMENTATION.

              METHOD class_setup.
                environment = cl_cds_test_environment=>create( i_for_entity = 'ZAC_SHR_CDSUT_DDLS' ).
              ENDMETHOD.

              METHOD setup.
                environment->clear_doubles( ).
              ENDMETHOD.

              METHOD class_teardown.
                environment->destroy( ).
              ENDMETHOD.

              METHOD aunit_for_cds_method.
                prepare_testdata( ).
                SELECT * FROM zac_shr_cdsut_ddls INTO TABLE @act_results.
                cl_abap_unit_assert=>fail( msg = 'Place your assertions here' ).
              ENDMETHOD.

              METHOD prepare_testdata.
                td_zac_shr_vtabl = VALUE #(
                  (
                    client = '100'
                    fld1 = 'TEST01'
                    fld2 = 'Test data'
                  )
                ).
                environment->insert_test_data( i_data = td_zac_shr_vtabl ).
              ENDMETHOD.

            ENDCLASS.

