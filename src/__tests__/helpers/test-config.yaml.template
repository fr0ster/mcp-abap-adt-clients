# Test Configuration for @mcp-abap-adt/adt-clients
#
# Usage:
#   cp src/__tests__/helpers/test-config.yaml.template src/__tests__/helpers/test-config.yaml
#   # Edit ONLY the lines marked with "# ← CHANGE" below
#
# ┌──────────────────────────────────────────────────────────────────┐
# │  REQUIRED CHANGES (edit these after copying):                    │
# │                                                                  │
# │  1. environment.default_package       — your dev package (Z*/Y*) │
# │  2. environment.default_transport     — transport request or ""  │
# │  3. environment.default_master_system — SAP system ID            │
# │  4. shared_dependencies.super_package — parent package           │
# │                                                                  │
# │  ON-PREM ONLY (if creating packages):                            │
# │  5. create_package.transport_layer    — e.g. "ZE19"             │
# └──────────────────────────────────────────────────────────────────┘
#
# IMPORTANT: Object Naming Convention
# ===================================
# All test objects must use the ZAC_* naming convention:
# - Classes: ZAC_CLS01, ZAC_CLS02, etc.
# - Domains: ZAC_DOM01, ZAC_DOM02, etc.
# - Data Elements: ZAC_DTEL01, ZAC_DTEL02, etc.
# - Function Modules: Z_AC_FM01, Z_AC_FM02, etc. (must start with Z_ or Y_)
# - Function Groups: ZAC_FGR01, ZAC_FGR02, etc.
# - Interfaces: ZAC_IF01, ZAC_IF02, etc.
# - Programs: ZAC_PROG01, ZAC_PROG02, etc.
# - Tables: ZAC_TAB01, ZAC_TAB02, etc.
# - TableTypes: ZAC_TTYP01, ZAC_TTYP02, etc.
# - Structures: ZAC_STRU01, ZAC_STRU02, etc.
# - Views: ZAC_VIEW01, ZAC_VIEW02, etc.
# - Service Definitions: ZAC_SRVD01, ZAC_SRVD02, etc.
# - Service Bindings: ZAC_SRVB01, ZAC_SRVB02, etc.
# - Packages: ZAC_PKG01, ZAC_PKG02, etc.
#
# Test settings
test_settings:
  fail_fast: false
  verbose: true
  timeout: 60000  # Global test timeout (60 seconds)
  retry_on_failure: false
  max_retries: 1
  cleanup_after_test: true
  allow_406: false  # Allow 406 Not Acceptable to be treated as skip (override per test case)
  # Timeouts for different operations (in milliseconds)
  timeouts:
    default: 60000
    long: 200000  # Long timeout for complex operations (group deletion, etc.)
    create: 60000
    delay: 3000  # Delay after delete/create operations
  # Operation delays (milliseconds) - time to wait for SAP to commit operations
  # These delays ensure SAP has time to persist state changes between operations
  operation_delays:
    lock: 3000      # Delay after lock operation (default: 3 seconds)
    unlock: 3000    # Delay after unlock operation (default: 3 seconds)
    update: 3000    # Delay after update operation (default: 3 seconds)
    create: 3000    # Delay after create operation (default: 3 seconds)
    activate: 3000   # Delay after activate operation (default: 3 seconds)
    default: 3000   # Default delay for any operation (default: 3 seconds)

# Session persistence configuration
session_config:
  # Enable session persistence (saves cookies and CSRF tokens)
  persist_session: true
  # Directory for session files (relative to project root)
  sessions_dir: ".sessions"
  # Session ID format: {test_name}_{timestamp} or custom
  session_id_format: "auto"  # "auto" or custom string
  # Clean up session after test
  cleanup_session_after_test: false

# Lock persistence configuration
lock_config:
  # Directory for lock files (relative to project root)
  locks_dir: ".locks"
  # Track locks in persistent storage
  persist_locks: true

# Environment configuration
environment:
  default_package: "ZADT_TEST"               # ← CHANGE: your dev package (Z*/Y*) or "$TMP" for local
  default_transport: ""                       # ← CHANGE: transport request (leave "" for $TMP/local packages)
  default_master_system: ""                   # ← CHANGE: SAP system ID (on-prem only, cloud gets it automatically)
  skip_cleanup: false    # Skip cleanup after test (objects left for analysis) - can be overridden per test case
  # connection_type: "rfc"  # Uncomment for legacy systems (BASIS < 7.50). Also set SAP_UNICODE=false in .env for non-unicode systems

# Shared dependencies — persistent Lego library for integration tests
# Objects are lazily created on first ensureSharedDependency() call, never deleted.
# Names are fixed across all systems — no placeholders needed.
# Naming convention: ZAC_SHR_{COMPONENT}_{OBJTYPE}
shared_dependencies:
  package: "ZAC_SHR_PKG"
  super_package: "ZADT_TEST"                 # ← CHANGE: parent package (same as environment.default_package)
  software_component: ""                     # e.g., HOME (leave empty for cloud)
  transport_layer: ""                        # e.g., ZE19 (leave empty for cloud)

  tables:
    - name: "ZAC_SHR_VTABL"
      description: "Shared table for View and CDS Unit Test"
      source: |
        @EndUserText.label : 'Shared table for View and CDS Unit Test'
        @AbapCatalog.enhancement.category : #NOT_EXTENSIBLE
        @AbapCatalog.tableCategory : #TRANSPARENT
        @AbapCatalog.deliveryClass : #A
        @AbapCatalog.dataMaintenance : #RESTRICTED
        define table zac_shr_vtabl {
          key client : abap.clnt not null;
          key fld1   : abap.char(10) not null;
          fld2       : abap.char(50);
          fld3       : abap.dec(10,2);
          fld4       : abap.dats;
        }

    - name: "ZAC_SHR_BTABL"
      description: "Shared table for BehaviorDefinition root view"
      source: |
        @EndUserText.label : 'Shared table for BehaviorDefinition'
        @AbapCatalog.enhancement.category : #NOT_EXTENSIBLE
        @AbapCatalog.tableCategory : #TRANSPARENT
        @AbapCatalog.deliveryClass : #A
        @AbapCatalog.dataMaintenance : #RESTRICTED
        define table zac_shr_btabl {
          key client : abap.clnt not null;
          key fld1   : abap.char(10) not null;
          fld2       : abap.char(50);
          fld3       : abap.dec(10,2);
          fld4       : abap.dats;
        }

    - name: "ZAC_SHR_ITABL"
      description: "Shared table for BehaviorImplementation root view"
      source: |
        @EndUserText.label : 'Shared table for BehaviorImplementation'
        @AbapCatalog.enhancement.category : #NOT_EXTENSIBLE
        @AbapCatalog.tableCategory : #TRANSPARENT
        @AbapCatalog.deliveryClass : #A
        @AbapCatalog.dataMaintenance : #RESTRICTED
        define table zac_shr_itabl {
          key client : abap.clnt not null;
          key fld1   : abap.char(10) not null;
          fld2       : abap.char(50);
        }

  views:
    - name: "ZAC_SHR_CDSUT_DDLS"
      description: "Shared CDS view for CDS Unit Test"
      source: |
        @EndUserText.label : 'Shared CDS view for CDS Unit Test'
        @AccessControl.authorizationCheck : #NOT_REQUIRED
        define view entity ZAC_SHR_CDSUT_DDLS
          as select from zac_shr_vtabl
        {
          key fld1,
          fld2,
          fld3,
          fld4
        }

    - name: "ZAC_SHR_BDEF_DDLS"
      description: "Shared CDS root view for BehaviorDefinition"
      source: |
        @EndUserText.label : 'Shared root view for BehaviorDefinition'
        @AccessControl.authorizationCheck : #NOT_REQUIRED
        define root view entity ZAC_SHR_BDEF_DDLS
          as select from zac_shr_btabl
        {
          key fld1,
          fld2,
          fld3,
          fld4
        }

    - name: "ZAC_SHR_BIMP_DDLS"
      description: "Shared CDS root view for BehaviorImplementation"
      source: |
        @EndUserText.label : 'Shared root view for BehaviorImplementation'
        @AccessControl.authorizationCheck : #NOT_REQUIRED
        define root view entity ZAC_SHR_BIMP_DDLS
          as select from zac_shr_itabl
        {
          key fld1,
          fld2
        }

  access_controls:
    - name: "ZAC_SHR_AC01"
      description: "Shared access control for CDS view ZAC_SHR_CDSUT_DDLS"
      source: |
        @EndUserText.label : 'Shared access control for ZAC_SHR_CDSUT_DDLS'
        @MappingRole : true
        define role ZAC_SHR_AC01 {
          grant select on ZAC_SHR_CDSUT_DDLS
          where ( ) = aspect pfcg_auth ( 'S_TABU_NAM', ACTVT = '03', TABLE = 'ZAC_SHR_CDSUT_DDLS' );
        }

  behavior_definitions:
    - name: "ZAC_SHR_BIMP_DDLS"
      description: "Shared BDEF for BehaviorImplementation"
      root_entity: "ZAC_SHR_BIMP_DDLS"
      implementation_type: "Managed"
      source: |
        managed implementation in class zac_bp_shr_bimp_ddls unique;
        strict ( 2 );

        define behavior for ZAC_SHR_BIMP_DDLS
        persistent table zac_shr_itabl
        lock master
        authorization master ( instance, global )
        {
          create;
          update;
          delete;
        }

  classes:
    - name: "ZAC_SHR_RUN01"
      description: "Shared runnable class (if_oo_adt_classrun) for profiler/executor tests"
      source: |
        CLASS zac_shr_run01 DEFINITION PUBLIC FINAL CREATE PUBLIC.
          PUBLIC SECTION.
            INTERFACES if_oo_adt_classrun.
        ENDCLASS.

        CLASS zac_shr_run01 IMPLEMENTATION.
          METHOD if_oo_adt_classrun~main.
            DO 5 TIMES.
              out->write( |Hello World { sy-index }| ).
            ENDDO.
          ENDMETHOD.
        ENDCLASS.

    - name: "ZAC_SHR_DMP01"
      description: "Shared dump class (division by zero) for runtime dumps tests"
      source: |
        CLASS zac_shr_dmp01 DEFINITION PUBLIC FINAL CREATE PUBLIC.
          PUBLIC SECTION.
            INTERFACES if_oo_adt_classrun.
        ENDCLASS.

        CLASS zac_shr_dmp01 IMPLEMENTATION.
          METHOD if_oo_adt_classrun~main.
            DATA lv_num TYPE i VALUE 1.
            DATA lv_den TYPE i VALUE 0.
            DATA lv_res TYPE i.
            lv_res = lv_num / lv_den.
            out->write( |ZAC_SHR_DMP01 result: { lv_res }| ).
          ENDMETHOD.
        ENDCLASS.

  interfaces:
    - name: "ZAC_SHR_IF01"
      description: "Shared interface for read-only tests"
      source: |
        INTERFACE zac_shr_if01 PUBLIC.
          METHODS get_value RETURNING VALUE(rv_value) TYPE string.
        ENDINTERFACE.

  function_groups:
    - name: "ZAC_SHR_FUGR"
      description: "Shared FUGR for FM tests"

  function_modules:
    - name: "Z_AC_SHR_FM01"
      function_group: "ZAC_SHR_FUGR"
      description: "Shared FM for read-only tests"
      source: |
        FUNCTION z_ac_shr_fm01.
        *"----------------------------------------------------------------------
        *"*"Local Interface:
        *"  IMPORTING
        *"     VALUE(IV_INPUT) TYPE  STRING
        *"  EXPORTING
        *"     VALUE(EV_OUTPUT) TYPE  STRING
        *"----------------------------------------------------------------------
          ev_output = |Result: { iv_input }|.
        ENDFUNCTION.

  service_definitions:
    - name: "ZAC_SHR_SRVD01"
      description: "Shared service definition for read-only tests"
      source: |
        @EndUserText.label: 'Shared service definition'
        define service ZAC_SHR_SRVD01 {
          expose ZAC_SHR_CDSUT_DDLS;
        }

  programs:
    - name: "ZAC_SHR_PROG"
      description: "Shared program for run tests"
      available_in: ["onprem", "legacy"]
      source: |
        REPORT ZAC_SHR_PROG.
        WRITE: / 'Shared test program'.

# Standard objects registry for read-only tests
# Uses shared dependencies (ZAC_SHR_*) where possible to avoid ABAP version dependencies.
# Only basic DDIC objects (MANDT, SYST, T000, etc.) use SAP standard names.
standard_objects:
  classes:
    - name: "ZAC_SHR_RUN01"
      description: "Shared runnable class (from shared_dependencies)"
      available_in: ["onprem", "cloud"]

  interfaces:
    - name: "ZAC_SHR_IF01"
      description: "Shared interface (from shared_dependencies)"
      available_in: ["onprem", "cloud"]

  # Basic DDIC objects — guaranteed to exist on all ABAP systems
  domains:
    - name: "MANDT"
      description: "Client domain"
      available_in: ["onprem", "cloud"]
    - name: "ABAP_BOOL"
      description: "Boolean domain"
      available_in: ["onprem", "cloud"]

  data_elements:
    - name: "MANDT"
      description: "Client data element"
      available_in: ["onprem", "cloud"]
    - name: "ABAP_BOOL"
      description: "Boolean data element"
      available_in: ["onprem", "cloud"]

  tables:
    - name: "T000"
      description: "Client table"
      available_in: ["onprem", "legacy", "cloud"]

  tabletypes:
    - name: "STRING_TABLE"
      description: "Standard string table type"
      available_in: ["onprem", "cloud"]

  structures:
    - name: "SYST"
      description: "System fields structure"
      available_in: ["onprem", "cloud"]

  packages:
    - name: "$TMP"
      description: "Local package"
      available_in: ["onprem"]
    - name: "ZLOCAL"
      description: "Placeholder for ABAP Cloud package – replace with existing package"
      available_in: ["cloud"]

  programs:
    - name: "ZAC_SHR_PROG"
      description: "Shared program (from shared_dependencies)"
      available_in: ["onprem"]

  views:
    - name: "ZAC_SHR_CDSUT_DDLS"
      description: "Shared CDS view (from shared_dependencies)"
      available_in: ["onprem", "cloud"]

  function_groups:
    - name: "ZAC_SHR_FUGR"
      description: "Shared function group (from shared_dependencies)"
      available_in: ["onprem", "cloud"]

  function_modules:
    - name: "Z_AC_SHR_FM01"
      group: "ZAC_SHR_FUGR"
      description: "Shared function module (from shared_dependencies)"
      available_in: ["onprem", "cloud"]

  service_definitions:
    - name: "ZAC_SHR_SRVD01"
      description: "Shared service definition (from shared_dependencies)"
      available_in: ["onprem", "cloud"]

  access_controls:
    - name: "ZAC_SHR_AC01"
      description: "Shared access control (from shared_dependencies)"
      available_in: ["onprem", "cloud"]

  service_bindings:
    - name: "ZAC_SRVB01"
      description: "Placeholder for service binding – replace with existing service binding"
      available_in: ["onprem", "cloud"]

  standard_criteria:
    note: "Most entries use shared dependencies (ZAC_SHR_*). Only basic DDIC uses SAP standard names."

# ============================================================================
# READ TESTS (Read-only operations on existing objects)
# ============================================================================
# 
# Each test case can specify `available_in` parameter to conditionally enable/disable
# tests for specific environments:
#   - available_in: ["cloud"] - only run on cloud systems
#   - available_in: ["onprem"] - only run on modern on-premise systems (BASIS >= 7.50)
#   - available_in: ["legacy"] - only run on legacy on-premise systems (BASIS < 7.50)
#   - available_in: ["onprem", "legacy"] - run on all on-premise systems
#   - available_in: ["cloud", "onprem"] or omit - run on cloud and modern on-premise
#
# Example:
#   - name: "my_test"
#     enabled: true
#     available_in: ["onprem"]  # Skip this test on cloud systems
#     params: {}
# ============================================================================

# Read Program (AdtClient)
# Uses standard_objects.programs with available_in filter
read_program:
  test_cases:
    - name: "readonly_read_program"
      enabled: true
      available_in: ["onprem"]  # Programs are not supported in cloud systems (BTP ABAP Environment)
      description: "Read existing program using AdtClient (uses standard_objects.programs). Programs are not supported in cloud systems."
      params: {}  # No params needed - automatically uses standard_objects.programs filtered by available_in

# Read Class (AdtClient)
# Uses standard_objects.classes with available_in filter
